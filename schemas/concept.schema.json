{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema-kg-rag.org/schemas/concept.schema.json",
  "title": "Schema Concept",
  "description": "Concept definition in the schema knowledge graph (core field metadata)",
  "type": "object",
  "required": ["concept_id", "canonical_name", "concept_type", "created_at"],
  "properties": {
    "concept_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Unique concept identifier (lowercase letters, digits, underscores)",
      "examples": ["revenue", "patient_age", "market_cap"]
    },
    "canonical_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Canonical name (standardized field name)",
      "examples": ["total_revenue", "patient_age_years", "market_capitalization"]
    },
    "concept_type": {
      "type": "string",
      "enum": ["metric", "dimension", "identifier", "temporal", "spatial", "categorical", "numerical"],
      "description": "Concept type"
    },
    "domain": {
      "type": "string",
      "enum": ["finance", "healthcare", "retail", "education", "government", "general"],
      "description": "Domain classification"
    },
    "definition": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000,
      "description": "Concept definition (clear semantic description)"
    },
    "attributes": {
      "type": "object",
      "description": "Concept attributes (unit, data type, resolution, etc.)",
      "properties": {
        "unit": {
          "type": "string",
          "description": "Unit of measurement",
          "examples": ["USD", "years", "percentage", "count"]
        },
        "data_type": {
          "type": "string",
          "enum": ["integer", "float", "string", "boolean", "date", "datetime", "categorical"],
          "description": "Data type"
        },
        "resolution": {
          "type": "string",
          "description": "Resolution (temporal, spatial, etc.)",
          "examples": ["daily", "monthly", "city-level", "country-level"]
        },
        "range": {
          "type": "object",
          "description": "Value range",
          "properties": {
            "min": {"type": "number"},
            "max": {"type": "number"}
          }
        },
        "format": {
          "type": "string",
          "description": "Format constraints (regular expression, date format, etc.)",
          "examples": ["YYYY-MM-DD", "^\\d{3}-\\d{2}-\\d{4}$"]
        }
      }
    },
    "parent_path": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Hierarchical path (from root to current concept)",
      "examples": [["Finance", "Statement", "Income", "Revenue"]]
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Tag list (for classification and retrieval)",
      "examples": [["financial", "quarterly", "revenue"]]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Concept confidence score (0-1)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Update timestamp"
    },
    "source": {
      "type": "string",
      "description": "Source (dataset name, file path, etc.)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version number (semantic versioning)",
      "examples": ["1.0.0", "2.1.3"]
    }
  },
  "additionalProperties": false
}
